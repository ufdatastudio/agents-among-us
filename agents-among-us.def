Bootstrap: docker
From: nvidia/cuda:12.4.1-devel-ubuntu22.04

%labels
    Author UF Research Computing
    Application Agents Among Us
    Version 1.0
    Description LLM-powered social deduction game simulation

%help
    Agents Among Us - Interactive web framework for simulating social deduction games using LLMs.

    Usage:
        # Run the web UI (default)
        apptainer run --nv agents-among-us.sif

        # Run with GPU support on HiPerGator
        apptainer run --nv --bind /blue:/blue agents-among-us.sif

        # Execute a specific command
        apptainer exec --nv agents-among-us.sif uv run python main.py --help

%environment
    export DEBIAN_FRONTEND=noninteractive
    export TZ=UTC
    export PATH="/root/.local/bin:$PATH"
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export HF_HOME=/app/.cache/huggingface
    export TRANSFORMERS_CACHE=/app/.cache/huggingface
    export LLM_MODE=LOCAL
    export PORT=${PORT:-8080}

%post
    # Update and install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        build-essential \
        cmake \
        libgomp1 \
        && rm -rf /var/lib/apt/lists/*

    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # Create app directory
    mkdir -p /app
    cd /app

    # Install Python 3.10 via uv and create venv
    uv python install 3.10
    uv venv --python 3.10

    # Install PyTorch with CUDA 12.4 support
    uv pip install \
        torch==2.5.1 \
        torchvision==0.20.1 \
        torchaudio==2.5.1 \
        --index-url https://download.pytorch.org/whl/cu124

    # Install core ML dependencies
    uv pip install \
        transformers==4.47.0 \
        accelerate==1.2.1 \
        bitsandbytes==0.45.0 \
        safetensors==0.4.5 \
        sentencepiece==0.2.0 \
        tokenizers==0.21.0 \
        huggingface-hub==0.27.0 \
        datasets==3.2.0 \
        peft==0.14.0

    # Install web and data processing dependencies
    uv pip install \
        flask==3.1.0 \
        pandas==2.2.3 \
        numpy==2.0.2 \
        scikit-learn==1.6.0 \
        xgboost==2.1.3 \
        joblib==1.4.2 \
        nltk==3.9.1 \
        matplotlib==3.9.3 \
        pillow==11.0.0 \
        tqdm==4.67.1 \
        pyyaml==6.0.2 \
        loguru==0.7.3

    # Download NLTK data
    uv run python -c "import nltk; nltk.download('punkt'); nltk.download('stopwords'); nltk.download('punkt_tab')"

    # Create necessary directories
    mkdir -p /app/logs /app/frontend/data /app/config/game_configs

    # Create startup script that supports configurable port
    cat > /app/start.sh << 'STARTSCRIPT'
#!/bin/bash
cd /app
PORT="${PORT:-8080}"
echo "Starting Agents Among Us on port ${PORT}..."
exec uv run python -c "
import sys
sys.path.insert(0, '/app')
from frontend.app import app
import os
port = int(os.environ.get('PORT', 8080))
app.run(host='0.0.0.0', port=port, debug=False)
"
STARTSCRIPT
    chmod +x /app/start.sh

%files
    # Copy application code into container
    # These paths are relative to the build context
    agents /app/agents
    config /app/config
    core /app/core
    frontend /app/frontend
    results/classifiers/models /app/results/classifiers/models
    main.py /app/main.py
    worker.py /app/worker.py

%runscript
    exec /app/start.sh "$@"

%startscript
    exec /app/start.sh "$@"
