Bootstrap: docker
From: ubuntu:22.04

%labels
    Author UF Research Computing
    Application Agents Among Us (Navigator)
    Version 1.0
    Description Lightweight navigator-only build for PubApps (no GPU/torch)

%help
    Agents Among Us - Navigator Mode
    Lightweight container that only exposes UF Navigator API models.
    No CUDA, torch, or local GPU inference.

    Usage:
        apptainer run --bind ./logs:/app/logs agents-among-us-navigator.sif

        # Custom port
        PORT=9090 apptainer run --bind ./logs:/app/logs agents-among-us-navigator.sif

%environment
    export DEBIAN_FRONTEND=noninteractive
    export TZ=UTC
    export PATH="/root/.local/bin:$PATH"
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export APP_MODE=navigator
    export LLM_MODE=LOCAL
    export PORT=${PORT:-8080}

%post
    # Update and install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
        curl \
        build-essential \
        cmake \
        libgomp1 \
        && rm -rf /var/lib/apt/lists/*

    # Install uv
    export TMPDIR=/tmp
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # Create app directory
    mkdir -p /app
    cd /app

    # Install Python 3.10 via uv
    uv python install 3.10

    # Install only base + api dependencies (no gpu extra)
    uv sync --extra api --no-install-project

    # Create necessary directories
    mkdir -p /app/logs /app/logs/game_configs /app/frontend/data

    # Create startup script that supports configurable port
    cat > /app/start.sh << 'STARTSCRIPT'
#!/bin/bash
cd /app
PORT="${PORT:-8080}"
echo "Starting Agents Among Us (Navigator Mode) on port ${PORT}..."
exec uv run python -c "
import sys
sys.path.insert(0, '/app')
from frontend.app import app
import os
port = int(os.environ.get('PORT', 8080))
app.run(host='0.0.0.0', port=port, debug=False)
"
STARTSCRIPT
    chmod +x /app/start.sh

%files
    # Copy dependency files first so uv sync works in %post
    pyproject.toml /app/pyproject.toml
    uv.lock /app/uv.lock
    # Copy application code
    agents /app/agents
    config /app/config
    core /app/core
    frontend /app/frontend
    main.py /app/main.py

%runscript
    exec /app/start.sh "$@"

%startscript
    exec /app/start.sh "$@"
